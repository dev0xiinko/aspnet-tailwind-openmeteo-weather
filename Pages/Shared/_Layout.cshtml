<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/practice1.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-950 text-slate-100 flex flex-col">
    <div class="flex-1 w-full">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-slate-800 text-muted">
        <div class="container-fluid py-3 text-xs text-slate-400">
            &copy; 2026 - practice1 -
            <a asp-area="" asp-page="/Privacy" class="text-sky-400 hover:text-sky-300">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>